# LLM Provider Selection
LLM_PROVIDER=groq  # Options: anthropic, groq, deepseek, openai, local, etc.
LLM_MODEL=llama-3.3-70b-versatile  # Model name for selected provider

# API Keys for all supported providers
ANTHROPIC_API_KEY=your_anthropic_key
GROQ_API_KEY=your_groq_key
DEEPSEEK_API_KEY=your_deepseek_key
OPENAI_API_KEY=your_openai_key

# Other ARIA settings
# LLM Provider
# Options: "groq" (free, fast), "openrouter" (multi-model), or "anthropic" (Claude, paid)
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=ARIA

# ARIA Settings
ARIA_OUTPUT_DIR=~/ARIA/outputs
ARIA_MAX_CONCURRENT_TASKS=4
ARIA_WEBSOCKET_PORT=8765
ARIA_MAX_STEPS_PER_TASK=40
ARIA_TASK_TIMEOUT_SECONDS=300
LOG_LEVEL=INFO

