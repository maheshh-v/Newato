{
  "name": "aria-electron",
  "version": "1.0.0",
  "description": "ARIA — Autonomous Reasoning & Intelligence Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.aria.agent",
    "productName": "ARIA",
    "directories": {
      "output": "../dist-installer"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "ARIA",
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!aria.db*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ]
  }
}
